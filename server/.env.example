# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/crypto-auction
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/crypto-auction

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# CORS Configuration
CLIENT_URL=http://localhost:1234

# Mail (Gmail App Password)
GMAIL_USER=your_gmail_here@example.com
GMAIL_PASS=your_gmail_app_password_here
MAIL_FROM="Crypto Auction <no-reply@crypto-auction.local>"
